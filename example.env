# Wolfx WebSocket endpoint override. Keep empty to connect all WOLFX_SOURCES via WOLFX_WS_BASE.
WOLFX_WS_URL=
WOLFX_WS_BASE=wss://ws-api.wolfx.jp
WOLFX_SOURCES=all_eew
WOLFX_LISTENER_ENABLED=1

# Global major earthquake source. EMSC/SeismicPortal sends new and updated events by WebSocket.
GLOBAL_QUAKE_LISTENER_ENABLED=1
GLOBAL_QUAKE_SOURCE_URL=wss://www.seismicportal.eu/standing_order/websocket
GLOBAL_QUAKE_MIN_MAGNITUDE=7.5

ALERT_RED_INTENSITY=4
ALERT_YELLOW_INTENSITY=2
BARK_RED_LEVEL=critical
BARK_RED_VOLUME=8
BARK_RED_SOUND=alarm
BARK_RED_REPEAT=3
BARK_RED_REPEAT_GAP_SECONDS=1.2
BARK_YELLOW_LEVEL=critical
BARK_YELLOW_VOLUME=4
BARK_YELLOW_SOUND=alarm
BARK_YELLOW_REPEAT=2
BARK_YELLOW_REPEAT_GAP_SECONDS=1
BARK_BLUE_LEVEL=timeSensitive
BARK_BLUE_VOLUME=
BARK_BLUE_SOUND=alarm
BARK_BLUE_REPEAT=1
BARK_BLUE_REPEAT_GAP_SECONDS=0

EEW_MAX_EVENTS=2000
EEW_MAX_DECISIONS=5000
EEW_MAX_PUSHES=2000

# Internal Bark server URL used by the EEW backend inside docker compose.
BARK_BASE_URL=http://bark-server:18762

# Strongly recommended when exposing the admin page through Tunnel/frp.
EEW_AUTH_TOKEN=

# Optional external URL opened from Bark notifications.
PUBLIC_BASE_URL=

EEW_DATA_DIR=/data

EEW_HUB_PORT=18761
BARK_HOST_PORT=18762

# Optional Cloudflare Zero Trust tunnel token.
# Example public hostnames:
# - eew.example.com  -> http://eew-hub:18761
# - bark.example.com -> http://bark-server:18762
CLOUDFLARED_TOKEN=
